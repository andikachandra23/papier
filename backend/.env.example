# Database (use PostgreSQL URL for production, SQLite for local dev)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Application
SECRET_KEY=change-this-to-a-long-random-secret
CORS_ORIGINS=https://your-app.up.railway.app
ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=60

# Cloudflare R2 (S3-compatible storage for PDFs)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# AI API (for PDF summarization)
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DEFAULT_MODEL=mimo-v2.5-pro

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External API contact email (used for OpenAlex & Unpaywall polite pools)
CONTACT_EMAIL=admin@papier.app

# kirim.email
KIRIM_EMAIL_AUTH_ID=
KIRIM_EMAIL_API_KEY=
KIRIM_EMAIL_LIST_ID=